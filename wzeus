local Controls = require(PlayerScripts:WaitForChild("PlayerModule")):GetControls()
local function LockControls(state)
    if state == true then Controls:Disable() else Controls:Enable() end
end

local function findActualSafeZone()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (string.find(string.upper(obj.Name), "SAFE") or string.find(string.upper(obj.Name), "ZONE")) then
            return obj.Position + Vector3.new(0, 3, 0)
        end
    end
    return lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") and lp.Character.HumanoidRootPart.Position
end

local _G_AutoKick = false
local FINAL_SPEED = 116
local targetSafeZonePos = nil

-- Cập nhật Speed khi người dùng nhập số
SpeedInput.FocusLost:Connect(function()
    local newSpeed = tonumber(SpeedInput.Text)
    if newSpeed then
        FINAL_SPEED = newSpeed
        print("Đã cập nhật tốc độ bay: " .. FINAL_SPEED)
    else
        SpeedInput.Text = tostring(FINAL_SPEED) -- Trả về cũ nếu nhập sai chữ
    end
end)

local function smoothMoveFinal(targetPos)
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    LockControls(true) 
    while _G_AutoKick and (targetPos - hrp.Position).Magnitude > 5 do
        local direction = (targetPos - hrp.Position).Unit
        hrp.CFrame = hrp.CFrame + direction * (FINAL_SPEED / 60)
        RunService.Heartbeat:Wait()
    end
    LockControls(false)
end

-- AUTO FARM LOGIC
AutoKickBtn.MouseButton1Click:Connect(function()
    _G_AutoKick = not _G_AutoKick
    if _G_AutoKick then
        AutoKickBtn.Text = "Auto Farm: BẬT"
        AutoKickBtn.TextColor3 = Color3.fromRGB(0, 255, 150)
        targetSafeZonePos = findActualSafeZone()
        local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if hrp and targetSafeZonePos then hrp.CFrame = CFrame.new(targetSafeZonePos) end

        task.spawn(function()
            while _G_AutoKick do
                pcall(function()
                    local E = ReplicatedStorage.Shared.Packages.Network:FindFirstChild("rev_KickEvent")
                    if E then E:FireServer(1) end
                    local item = nil
                    for _, o in ipairs(workspace:GetDescendants()) do
                        if o:IsA("BasePart") and (string.find(string.lower(o.Name), "brainrot") or string.find(string.lower(o.Name), "drop")) then
                            item = o; break end end
                    if item then smoothMoveFinal(item.Position); task.wait(0.05) end
                    smoothMoveFinal(targetSafeZonePos)
                end)
                task.wait(0.1)
            end
        end)
    else
        AutoKickBtn.Text = "Auto Farm: TẮT"
        AutoKickBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
        LockControls(false)
    end
end)

-- AUTO TRAIN LOGIC
local _G_AutoTrain = false
local function findBestTrainingTool()
    local backpack = lp:FindFirstChild("Backpack")
    if not backpack then return nil end
    local keywords = {"weight", "dumbbell", "barbell", "strength", "kick", "tạ"}
    for _, tool in ipairs(backpack:GetChildren()) do
        if tool:IsA("Tool") then
            local nL = string.lower(tool.Name)
            for _, k in ipairs(keywords) do if string.find(nL, k) then return tool end end
        end
    end
    return backpack:FindFirstChildOfClass("Tool")
end

local function obliterateX2Buttons()
    local function scan(folder)
        if not folder then return end
        for _, ui in ipairs(folder:GetDescendants()) do
            if ui:IsA("GuiButton") and ui.Visible then
                local data = string.lower(ui.Name)
                if ui:IsA("TextButton") then data = data .. string.lower(ui.Text) end
                for _, c in ipairs(ui:GetChildren()) do if c:IsA("TextLabel") then data = data .. string.lower(c.Text) end end
                
                if string.find(data, "x2") or string.find(data, "click") then
                    if firesignal then 
                        pcall(function() firesignal(ui.Activated) firesignal(ui.MouseButton1Click) end) 
                    end
                end
            end
        end
    end
    scan(lp:FindFirstChild("PlayerGui"))
end

AutoTrainBtn.MouseButton1Click:Connect(function()
    _G_AutoTrain = not _G_AutoTrain
    if _G_AutoTrain then
        AutoTrainBtn.Text = "Auto Train: BẬT"
        AutoTrainBtn.TextColor3 = Color3.fromRGB(0, 255, 150)
        task.spawn(function()
            local lastX2Scan = 0 -- Khởi tạo biến đếm thời gian
            while _G_AutoTrain do
                local char = lp.Character
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                if char and hum then
                    local tool = char:FindFirstChildOfClass("Tool")
                    if not tool then
                        local best = findBestTrainingTool()
                        if best then hum:EquipTool(best) end
                    end
                    if char:FindFirstChildOfClass("Tool") then char:FindFirstChildOfClass("Tool"):Activate() end
                    
                    -- CHỈ QUÉT NÚT X2 MỖI 1 GIÂY 1 LẦN (GIẢM LAG)
                    if os.clock() - lastX2Scan >= 1 then
                        obliterateX2Buttons()
                        lastX2Scan = os.clock()
                    end
                    
                    for _, r in ipairs(ReplicatedStorage:GetDescendants()) do
                        if r:IsA("RemoteEvent") and (string.find(r.Name:lower(), "train") or string.find(r.Name:lower(), "click")) then
                            r:FireServer()
                        end
                    end
                end
                task.wait(0.01)
            end
        end)
    else
        AutoTrainBtn.Text = "Auto Train: TẮT"
        AutoTrainBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
        if lp.Character and lp.Character:FindFirstChildOfClass("Humanoid") then
            lp.Character.Humanoid:UnequipTools()
        end
    end
end)

-- AUTO LỤM TIỀN LOGIC (TÍCH HỢP)
local _G_AutoMoney = false

local function isPartGreen(part)
    local c = part.Color
    return (c.G > c.R and c.G > c.B)
end

AutoMoneyBtn.MouseButton1Click:Connect(function()
    _G_AutoMoney = not _G_AutoMoney
    if _G_AutoMoney then
        AutoMoneyBtn.Text = "Auto Lụm Tiền: BẬT"
        AutoMoneyBtn.TextColor3 = Color3.fromRGB(0, 255, 150)
        task.spawn(function()
            while _G_AutoMoney do
                pcall(function()
                    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        for _, gui in ipairs(workspace:GetDescendants()) do
                            if (gui:IsA("SurfaceGui") or gui:IsA("BillboardGui")) then
                                local part = gui.Adornee or gui.Parent
                                if part and part:IsA("BasePart") and isPartGreen(part) then
                                    local hasMoney = false
                                    for _, el in ipairs(gui:GetDescendants()) do
                                        if (el:IsA("TextLabel") or el:IsA("TextButton")) and (string.find(el.Text, "%$") or string.find(el.Text:lower(), "free")) then
                                            hasMoney = true 
                                            break
                                        end
                                    end
                                    if hasMoney then
                                        hrp.CFrame = CFrame.new(part.Position + Vector3.new(0, 1.2, 0))
                                        task.wait(0.05)
                                    end
                                end
                            end
                        end
                    end
                end)
                task.wait(5) 
            end
        end)
    else
        AutoMoneyBtn.Text = "Auto Lụm Tiền: TẮT"
        AutoMoneyBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
end)

